---
import Main from "../layouts/Main.astro";
import Hero from "../components/react/Hero.tsx";
import Timeline from "../components/react/Timeline.tsx";
import CaseStudies from "../components/react/CaseStudies.tsx";
import TechStack from "../components/react/TechStack.tsx";
import Footer from "../components/react/Footer.tsx";
---

<Main>
  {/* Hero loads eagerly so its entrance animation runs on first paint. */}
  <Hero client:load />
  <Timeline client:visible />
  <CaseStudies client:visible />
  <TechStack client:visible />
  <Footer client:visible />
</Main>
